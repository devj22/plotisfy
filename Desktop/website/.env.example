# PostgreSQL (Neon) — never commit real credentials
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"

# Storage (use Cloudinary or S3/R2)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_api_key

# Analytics & Tracking
NEXT_PUBLIC_GA4_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXX

# Contact Info (public)
NEXT_PUBLIC_WHATSAPP_NUMBER=919820000000
NEXT_PUBLIC_PHONE=+91 98200 00000
NEXT_PUBLIC_EMAIL=hello@plotsify.com

# Site URL
NEXT_PUBLIC_SITE_URL=https://plotsify.com

# Admin Auth (Payload CMS or custom)
NEXTAUTH_SECRET=your_secret_here
NEXTAUTH_URL=http://localhost:3000
